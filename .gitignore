# =============================================================================
# .gitignore — HeatSuite 2024
# =============================================================================

# -----------------------------------------------------------------------------
# DATA AND RESULTS — excluded from GitHub
# Processed Data are publicly available at 
# Results (figures, tables) are generated by running the PRG/ scripts
# -----------------------------------------------------------------------------
DAT/
RES/

# Keep folder structure visible on GitHub (empty folders need a placeholder)
!DAT/.gitkeep
!DAT/Raw/.gitkeep
!DAT/Processed/.gitkeep
!RES/.gitkeep
!RES/Physiological/.gitkeep
!RES/Physiological/Graph/.gitkeep
!RES/Physiological/Table/.gitkeep
!RES/Environmental/.gitkeep
!RES/Environmental/Graph/.gitkeep
!RES/Environmental/Table/.gitkeep
!RES/Perceptuals/.gitkeep
!RES/Perceptuals/Graph/.gitkeep
!RES/Perceptuals/Table/.gitkeep

# -----------------------------------------------------------------------------
# KNITTED HTML OUTPUTS — excluded (generated from Rmd, not source code)
# -----------------------------------------------------------------------------
*.html
*.nb.html

# -----------------------------------------------------------------------------
# R AND RMARKDOWN TEMPORARY FILES
# -----------------------------------------------------------------------------
.Rhistory
.RData
.Rapp.history
*.Rproj.user/

# Rmarkdown cache and intermediate files
*_cache/
*_files/
*.knit.md
*.utf8.md

# -----------------------------------------------------------------------------
# OS FILES
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Windows
desktop.ini

# -----------------------------------------------------------------------------
# EDITOR FILES
# -----------------------------------------------------------------------------
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# SENSITIVE FILES — never commit these
# -----------------------------------------------------------------------------
# API keys, tokens, credentials
*.env
.Renviron
secrets.R
